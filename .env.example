MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/
MONGODB_DB=grant_project_manager
# Required outside local development. Rotate this to invalidate all existing signed sessions.
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_COOKIE_SAMESITE=lax
ADMIN_EMAILS=admin@example.com

# Email delivery. Without SMTP_HOST emails are printed to the server console.
# Local dev option: Mailpit/MailHog on port 1025.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM="Research Navigator <no-reply@localhost>"
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# Optional AI syllabus import. Keep the key server-side only.
OPENAI_API_KEY=
OPENAI_SYLLABUS_MODEL=gpt-5.4-mini

# Zenodo API. Use sandbox first; production tokens are separate from sandbox tokens.
ZENODO_API_TOKEN=replace-with-zenodo-token
ZENODO_API_BASE_URL=https://sandbox.zenodo.org/api
ZENODO_DEFAULT_COMMUNITY=

# File storage: local keeps files in .data/project-record-files; r2 stores new uploads in Cloudflare R2.
FILE_STORAGE_DRIVER=local
RECORD_UPLOAD_MAX_FILES=10
RECORD_UPLOAD_MAX_BYTES=26214400
# Set FILE_SCAN_MODE=required in production only after FILE_SCAN_PROVIDER is wired.
FILE_SCAN_MODE=disabled
FILE_SCAN_PROVIDER=
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=research-os
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_REGION=auto

# Local Mongo fallback is intentionally disabled by default.
MONGO_FALLBACK_TO_LOCAL=false
